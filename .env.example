# App
ENV=production
PORT=3000

# App — required by Joi validation schema
DATABASE_URL=postgresql://postgres:postgres@pg:5432/whiz_gateway
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
META_VERIFY_TOKEN=
META_APP_SECRET=
DISPATCH_MAX_RETRIES=5
DISPATCH_BACKOFF_BASE_MS=1000

# Postgres service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=whiz_gateway
POSTGRES_PORT=5432

# Redis service
REDIS_PORT=6379

# RabbitMQ service
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_ERLANG_COOKIE=changeme
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672
